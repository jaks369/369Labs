# =============================================================================
# REQUIRED â€” The app will not function without these
# =============================================================================

# MySQL connection string
# Example: mysql://user:password@host:3306/dbname
DATABASE_URL=""

# JWT secret for session signing (generate a long random string)
JWT_SECRET=""

# 32-byte hex key for encrypting Deriv API tokens at rest
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# =============================================================================
# OPTIONAL â€” Used for specific features
# =============================================================================

# Email auto-assigned admin role on signup
OWNER_EMAIL=""

# Deriv API (for server-side validation/trading if implemented)
DERIV_API_APP_ID=""

# RuFlo agent orchestration â€” falls back to OPENAI_* values when unset
RUFLO_API_KEY=""
RUFLO_API_URL=""
RUFLO_MODEL="gpt-4.1-mini"

# Client-side Deriv WebSocket app ID (default: 1089 for demo)
VITE_DERIV_APP_ID="1089"

# =============================================================================
# DEPLOYMENT
# =============================================================================

NODE_ENV="development"
PORT=3000
