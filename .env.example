# =============================================================================
# REQUIRED — The app will not function without these
# =============================================================================

# MySQL connection string
# Example: mysql://user:password@host:3306/dbname
DATABASE_URL=""

# JWT secret for session signing (generate a long random string)
JWT_SECRET=""

# 32-byte hex key for encrypting Deriv API tokens at rest
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=""

# =============================================================================
# OPTIONAL — Used for specific features
# =============================================================================

# Resend API key for transactional email (password reset, email verification)
# Get one at https://resend.com
RESEND_API_KEY=""

# Google OAuth credentials (for "Login with Google")
# Get them at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth credentials (for "Login with GitHub")
# Get them at https://github.com/settings/developers
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# From address for transactional emails (must be verified in Resend)
EMAIL_FROM="noreply@369labs.com"

# Public-facing URL of your app (used in email links)
APP_URL="http://localhost:3000"

# Email auto-assigned admin role on signup
OWNER_EMAIL=""

# Deriv API (for server-side validation/trading if implemented)
DERIV_API_APP_ID=""

# AI API key (used by forge; can be any OpenAI-compatible provider)
AI_API_KEY=""
AI_API_BASE_URL="https://api.openai.com/v1"

# RuFlo agent orchestration — falls back to OPENAI_* values when unset
RUFLO_API_KEY=""
RUFLO_API_URL=""
RUFLO_MODEL="gpt-4.1-mini"

# Client-side Deriv WebSocket app ID (default: 1089 for demo)
VITE_DERIV_APP_ID="1089"

# =============================================================================
# DEPLOYMENT
# =============================================================================

NODE_ENV="development"
PORT=3000
