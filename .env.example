# Database Configuration
DATABASE_URL="mysql://user:password@host:port/dbname"

# Auth Configuration (self-hosted)
JWT_SECRET="replace_with_a_long_random_string"

# Optional: makes this email an admin on signup
OWNER_EMAIL=""

# Optional: Deriv API (for server-side validation/trading if implemented)
DERIV_API_APP_ID="your_deriv_app_id"

# RuFlo agent orchestration — server-side only. Falls back to OPENAI_* values
# when these are unset.
RUFLO_API_KEY=""
RUFLO_API_URL=""
RUFLO_MODEL="gpt-4.1-mini"

NODE_ENV="development"
PORT=3000
